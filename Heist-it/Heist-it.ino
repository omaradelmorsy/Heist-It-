int charIndex(char c) {
  if (c >= 'A' && c <= 'Z') return c - 'A';
  if (c >= '0' && c <= '9') return c - '0' + 26;
  if (c == ' ') return 36;
  if (c == '!') return 37;
  if (c == ':') return 38;
  if (c == '-') return 39;
  if (c == ')') return 40;
  return 36;
}

void oledChar(char c) {
  int idx = charIndex(c);
  for (int i = 0; i < 5; i++)
    oledData(font5x7[idx][i]);
  oledData(0x00);
}

void oledText(uint8_t col, uint8_t page, const char* str) {
  oledSetCursor(col, page);
  while (*str)
    oledChar(*str++);
}

void oledLine(uint8_t page) {
  oledSetCursor(0, page);
  for (int i = 0; i < 128; i++)
    oledData(0xFF);
}



