void oledBigDigit(uint8_t col, uint8_t startPage, uint8_t digit) {
  for (uint8_t p = 0; p < 3; p++) {
    oledSetCursor(col, startPage + p);
    for (uint8_t i = 0; i < 16; i++)
      oledData(bigDigit[digit][p][i]);
  }
}


void showScore(int s) {
  oledClear();
  oledText(22, 0, "HEIST-IT!");
  oledLine(1);
  if (s < 10)
    oledBigDigit(56, 2, s);          // single digit centered
  else if (s < 100) {
    oledBigDigit(36, 2, s / 10);     // first digit
    oledBigDigit(72, 2, s % 10);     // second digit
  } else {
    oledBigDigit(8,  2, s / 100);         // hundreds
    oledBigDigit(46, 2, (s / 10) % 10);  // tens
    oledBigDigit(84, 2, s % 10);         // ones
  }
}

void showMessage(const char* line1, const char* line2) {
  oledClear();
  int len1 = strlen(line1);
  int len2 = strlen(line2);
  uint8_t x1 = (21 - len1) * 3;
  uint8_t x2 = (21 - len2) * 3;
  oledText(max(0, (int)x1), 2, line1);
  oledText(max(0, (int)x2), 5, line2);
}

void showCommand(const char* cmd) {
  oledClear();
  oledText(22, 0, "HEIST-IT!");
  oledLine(1);
  int len = strlen(cmd);
  uint8_t x = (21 - len) * 3;
  oledText(max(0, (int)x), 3, cmd);
}

void showWaiting() {
  oledClear();
  oledText(10, 0, "HEIST-IT!");
  oledLine(1);
  oledText(4, 3, "PRESS SW1 TO");
  oledText(10, 5, "START GAME");
}


Move pickMove() {
  return (Move)random(0, 3);
}

void giveCommand(Move m) {
  resetDial();
  resetJiggle();
  delay(150);

  if (m == DIAL)   { play(1); showCommand("DIAL IT!");   }
  if (m == FIRE)   { play(2); showCommand("FIRE IT!");   }
  if (m == JIGGLE) { play(3); showCommand("JIGGLE IT!"); }

  resetDial();
  resetJiggle();
  lastEncoder = (analogRead(ENCODER_PIN) > 512);
  delay(50);
}

bool gotItRight(Move m) {
  if (m == DIAL)   return getDial() >= 2;
  if (m == FIRE)   return fireArmed && reedTriggered();
  if (m == JIGGLE) return jiggleArmed && jiggleCount >= 1;
  return false;
}

bool gotItWrong(Move m) {
  if (m == DIAL)   return reedTriggered() || (vcnlArmed && magnetClose());
  if (m == FIRE)   return fireArmed && (getDial() >= 2 || (vcnlArmed && magnetClose()));
  if (m == JIGGLE) return jiggleArmed && reedTriggered();
  return false;
}

void win() {
  play(6);
  unlock();
  showMessage("YOU WIN!", "DIAMOND  )");
  blink(true, 10, 120);
  playing = false;
}

void lose() {
  play(5);
  lock();
  showMessage("CAUGHT!", "GAME OVER");
  blink(false, 6, 180);
  playing = false;
}

void startNewGame() {
  score       = 0;
  timeLeft    = 60000;
  dialCount   = 0;
  dialBase    = 0;
  lastEncoder = (analogRead(ENCODER_PIN) > 512);
  lock();
  ledsOff();
  blink(true, 2, 150);
  delay(1200);
  showScore(0);
  playing = true;
}



void setup() {
  pinMode(GREEN_LED,     OUTPUT);
  pinMode(RED_LED,       OUTPUT);
  ledsOff();

  pinMode(ENCODER_PIN,   INPUT);
  pinMode(REED_PIN,      INPUT);
  pinMode(START_BTN_PIN, INPUT_PULLUP);

  servo.attach(SERVO_PIN);
  lock();

  Wire.begin();
  oledInit();
  oledClear();

  setupProximity();
  setupAudio();

  randomSeed(analogRead(A2));
  blink(true, 3, 100);
  showWaiting();
}

void loop() {
  pollEncoder();

  if (!playing) {
    greenOn(); delay(400);
    ledsOff(); delay(400);

    if (gameStart || digitalRead(START_BTN_PIN) == LOW) {
      delay(50);
      gameStart = false;
      startNewGame();
    }
    return;
  }

  Move current = pickMove();
  giveCommand(current);

  unsigned long deadline = millis() + timeLeft;
  bool done = false;

  while (millis() < deadline) {
    pollEncoder();
    if (current == JIGGLE) pollJiggle();
    if (current == FIRE)   pollFireArm();
    if (current == DIAL || current == FIRE) pollVcnlArm();

    if (gotItWrong(current)) {
      lose();
      done = true;
      break;
    }

    if (gotItRight(current)) {
      score++;
      showScore(score);
      greenOn();
      play(4);
      delay(500);
      ledsOff();
      timeLeft -= 50;
      if (timeLeft < 400)   timeLeft = 400;
      if (timeLeft > 60000) timeLeft = 60000;
      done = true;
      break;
    }

    delay(20);
  }

  if (!done) lose();
  if (playing && score >= 99) win();
  if (!playing) {
    delay(3000);
    showWaiting();
  }
}
