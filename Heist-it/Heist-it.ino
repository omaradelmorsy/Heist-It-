//Some libraries I needed them 
#include <Wire.h>
#include <Servo.h>

#define GREEN_LED    8    // PB0
#define RED_LED      9    // PB1
#define SERVO_PIN    10   // PB2
#define ENCODER_PIN  A0   // PC0
#define REED_PIN     A1   // PC1

#define VCNL_ADDR    0x60
#define DFP_ADDR     0x3F
#define OLED_ADDR    0x3C

Servo servo;

int score        = 0;
long timeLeft    = 2000;
bool playing     = false;

int dialCount    = 0;
int dialBase     = 0;
bool fireHit     = false;
bool lastEncoder = false;
bool gameStart   = false;

enum Move { DIAL, FIRE, JIGGLE };  //Our three commands

void greenOn() {   //Green
  digitalWrite(GREEN_LED, HIGH);
  digitalWrite(RED_LED, LOW);
}

void redOn() {   //red
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, HIGH);
}

void ledsOff() {
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, LOW);
}

void blink(bool green, int times, int ms) {
  for (int i = 0; i < times; i++) {
    green ? greenOn() : redOn();
    delay(ms);
    ledsOff();
    delay(ms);
  }
}

void lock() {
  servo.write(0);
  delay(300);
}

void unlock() {
  servo.write(90);
  delay(300);
}

void resetDial() {
  dialBase = dialCount;
}

int getDial() {
  return dialCount - dialBase;
}

void resetFire() {
  fireHit = false;
}

void pollEncoder() {
  bool current = (analogRead(ENCODER_PIN) > 512);
  if (current && !lastEncoder) {
    if (!playing)
    gameStart = true;
    else
    dialCount++;
  }
  lastEncoder = current;
}

void pollReed() {
  if (analogRead(REED_PIN) > 512)
    fireHit = true;
}

void i2cSend(uint8_t addr, uint8_t reg, uint8_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

void i2cSend16(uint8_t addr, uint8_t reg, uint8_t low, uint8_t high) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(low);
  Wire.write(high);
  Wire.endTransmission();
}

uint16_t i2cGet(uint8_t addr, uint8_t reg) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(addr, (uint8_t)2);
  uint16_t lo = Wire.read();
  uint16_t hi = Wire.read();
  return (hi << 8) | lo;
}

void dfpSend(uint8_t cmd, uint8_t arg1, uint8_t arg2) {
  uint8_t checksum = (0xAA + cmd + 0x02 + arg1 + arg2) & 0xFF;
  Wire.beginTransmission(DFP_ADDR);
  Wire.write(0xAA);
  Wire.write(cmd);
  Wire.write(0x02);
  Wire.write(arg1);
  Wire.write(arg2);
  Wire.write(checksum);
  Wire.endTransmission();
  delay(30);
}

void setVolume(int vol) {
  dfpSend(0x06, 0x00, vol);
}

void play(int track) {
  dfpSend(0x0F, 0x01, track);
}

void setupAudio() {
  delay(1000);
  setVolume(25);
}

void setupProximity() {
  i2cSend(VCNL_ADDR,   0x00, 0x01);
  i2cSend16(VCNL_ADDR, 0x03, 0x04, 0x08);
  i2cSend16(VCNL_ADDR, 0x04, 0x00, 0x07);
}

bool magnetClose() {
  return i2cGet(VCNL_ADDR, 0x08) > 300;
}

bool fireDetected() {
  return fireHit || magnetClose();
}

void oledCmd(uint8_t cmd) {
  Wire.beginTransmission(OLED_ADDR);
  Wire.write(0x00);
  Wire.write(cmd);
  Wire.endTransmission();
}

void oledData(uint8_t data) {
  Wire.beginTransmission(OLED_ADDR);
  Wire.write(0x40);
  Wire.write(data);
  Wire.endTransmission();
}

void oledInit() {   //OLED Commands
  delay(100);
  oledCmd(0xAE);
  oledCmd(0xA8); oledCmd(0x3F);
  oledCmd(0xD3); oledCmd(0x00);
  oledCmd(0x40);
  oledCmd(0xA1);
  oledCmd(0xC8);
  oledCmd(0xDA); oledCmd(0x12);
  oledCmd(0x81); oledCmd(0xCF);
  oledCmd(0xA4);
  oledCmd(0xA6);
  oledCmd(0xD5); oledCmd(0x80);
  oledCmd(0xD9); oledCmd(0xF1);
  oledCmd(0xDB); oledCmd(0x40);
  oledCmd(0x20); oledCmd(0x00);
  oledCmd(0x8D); oledCmd(0x14);
  oledCmd(0xAF);
}

void oledClear() {
  for (uint8_t page = 0; page < 8; page++) {
    oledCmd(0xB0 + page);
    oledCmd(0x00);
    oledCmd(0x10);
    for (uint8_t col = 0; col < 128; col++)
      oledData(0x00);
  }
}

void oledSetCursor(uint8_t col, uint8_t page) {
  oledCmd(0xB0 + page);
  oledCmd(0x00 + (col & 0x0F));
  oledCmd(0x10 + (col >> 4));
}

