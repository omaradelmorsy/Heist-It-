void oledBigDigit(uint8_t col, uint8_t startPage, uint8_t digit) {
  for (uint8_t p = 0; p < 3; p++) {
    oledSetCursor(col, startPage + p);
    for (uint8_t i = 0; i < 16; i++)
      oledData(bigDigit[digit][p][i]);
  }
}

void showScore(int s) {
  oledClear();
  oledText(22, 0, "HEIST-IT!");
  oledLine(1);
  if (s < 10)
    oledBigDigit(56, 2, s);
  else if (s < 100) {
    oledBigDigit(38, 2, s / 10);
    oledBigDigit(72, 2, s % 10);
  } else {
    oledBigDigit(16, 2, s / 100);
    oledBigDigit(50, 2, (s / 10) % 10);
    oledBigDigit(84, 2, s % 10);
  }
}

void showMessage(const char* line1, const char* line2) {
  oledClear();
  int len1 = strlen(line1);
  int len2 = strlen(line2);
  uint8_t x1 = (21 - len1) * 3;
  uint8_t x2 = (21 - len2) * 3;
  oledText(max(0, (int)x1), 2, line1);
  oledText(max(0, (int)x2), 5, line2);
}

void showCommand(const char* cmd) {
  oledClear();
  oledText(22, 0, "HEIST-IT!");
  oledLine(1);
  int len = strlen(cmd);
  uint8_t x = (21 - len) * 3;
  oledText(max(0, (int)x), 3, cmd);
}

void showWaiting() {
  oledClear();
  oledText(10, 0, "HEIST-IT!");
  oledLine(1);
  oledText(4, 3, "PRESS SW1 TO");
  oledText(10, 5, "START GAME");
}

Move pickMove() {
  return (Move)random(0, 3);
}

void giveCommand(Move m) {
  resetDial();
  resetFire();
  if (m == DIAL)   { 
    play(1); 
    showCommand("DIAL IT!");  
     }
  if (m == FIRE)   { 
    play(2); 
    showCommand("FIRE IT!");   }
  if (m == JIGGLE) { 
    play(3); 
    showCommand("JIGGLE IT!"); 
    }
}

bool gotItRight(Move m) {
  if (m == DIAL)   
  return getDial() >= 5;
  if (m == FIRE)  
   return fireDetected();
  if (m == JIGGLE) 
  return getDial() >= 20;
  return false;
}

bool gotItWrong(Move m) {
  if (m == DIAL)   
  return fireDetected();
  if (m == FIRE)  
   return getDial() >= 5;
  if (m == JIGGLE) 
  return fireDetected();
  return false;
}

void win() {
  play(6);
  unlock();
  showMessage("YOU WIN!", "DIAMOND  )");
  blink(true, 10, 120);
  playing = false;
}

void lose() {
  play(5);
  lock();
  showMessage("CAUGHT!", "GAME OVER");
  blink(false, 6, 180);
  playing = false;
}

void startNewGame() {
  score     = 0;
  timeLeft  = 2000;
  dialCount = 0;
  dialBase  = 0;
  lock();
  ledsOff();
  blink(true, 2, 150);
  delay(1200);
  showScore(0);
  playing = true;
  Serial.println("Game started!");
}

void setup() {
  Serial.begin(9600);

  pinMode(GREEN_LED, OUTPUT);
  pinMode(RED_LED,   OUTPUT);
  ledsOff();

  pinMode(ENCODER_PIN, INPUT);
  pinMode(REED_PIN,    INPUT);

  servo.attach(SERVO_PIN);
  lock();

  Wire.begin();
  oledInit();
  oledClear();

  setupProximity();
  setupAudio();

  randomSeed(analogRead(A2));
  blink(true, 3, 100);
  showWaiting();
  Serial.println("Ready - turn dial to start!");
}

void loop() {
  pollEncoder();
  pollReed();

  if (!playing) {
    greenOn(); delay(400);
    ledsOff(); delay(400);

    if (gameStart) {
      delay(50);
      gameStart = false;
      startNewGame();
    }
    return;
  }

  Move current = pickMove();
  giveCommand(current);

  unsigned long deadline = millis() + timeLeft;
  bool done = false;

  while (millis() < deadline) {
    pollEncoder();
    pollReed();

    if (gotItRight(current)) {
      score++;
      showScore(score);
      greenOn();
      play(4);
      delay(500);
      ledsOff();

      timeLeft -= 50;
      if (timeLeft < 400)
        timeLeft = 400;

      Serial.print("Score: ");
      Serial.println(score);
      done = true;
      break;
    }

    if (gotItWrong(current)) {
      lose();
      done = true;
      break;
    }

    delay(20);
  }

  if (!done) {
    Serial.println("Too slow!");
    lose();
  }

  if (playing && score >= 99)
    win();

  if (!playing) {
    delay(3000);
    showWaiting();
  }
}
