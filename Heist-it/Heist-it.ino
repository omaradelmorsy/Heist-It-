//Some libraries I needed them 
#include <Wire.h>
#include <Servo.h>

#define GREEN_LED     8
#define RED_LED       9
#define SERVO_PIN     10
#define ENCODER_PIN   A0
#define REED_PIN      A1
#define START_BTN_PIN 2

#define VCNL_ADDR     0x60
#define OLED_ADDR     0x3C

#define PROX_THRESHOLD 2000

Servo servo;

int score        = 0;
unsigned long timeLeft = 60000;
bool playing     = false;

int dialCount    = 0;
int dialBase     = 0;
bool lastEncoder = false;
bool gameStart   = false;

int jiggleCount  = 0;
bool lastMagnet  = false;
bool fireArmed   = false;
bool jiggleArmed = false;
bool vcnlArmed   = false;

enum Move { DIAL, FIRE, JIGGLE };



void greenOn() {
  digitalWrite(GREEN_LED, HIGH);
  digitalWrite(RED_LED, LOW);
}

void redOn() {
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, HIGH);
}

void ledsOff() {
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, LOW);
}

void blink(bool green, int times, int ms) {
  for (int i = 0; i < times; i++) {
    green ? greenOn() : redOn();
    delay(ms);
    ledsOff();
    delay(ms);
  }
}



void lock()   { servo.write(0);  delay(300); }
void unlock() { servo.write(90); delay(300); }



void resetDial() { dialBase = dialCount; }
int  getDial()   { return dialCount - dialBase; }



void i2cSend(uint8_t addr, uint8_t reg, uint8_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

void i2cSend16(uint8_t addr, uint8_t reg, uint8_t low, uint8_t high) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(low);
  Wire.write(high);
  Wire.endTransmission();
}

uint16_t i2cGet(uint8_t addr, uint8_t reg) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(addr, (uint8_t)2);
  uint16_t lo = Wire.read();
  uint16_t hi = Wire.read();
  return (hi << 8) | lo;
}




void dfSend(const char* cmd) {
  Serial.print(cmd);
  Serial.print("\r\n");
  delay(100);
}

void play(int track) {
  char cmd[30];
  sprintf(cmd, "AT+PLAYFILE=/000%d.mp3", track);
  Serial.print(cmd);
  Serial.print("\r\n");
  delay(200);
}

void setupAudio() {
  Serial.begin(115200);
  delay(1000);
  dfSend("AT+PLAYMODE=3");  // single play — plays one file then stops
  delay(300);
  dfSend("AT+SAVE");        // save to memory permanently
  delay(300);
  dfSend("AT+VOL=20");      // volume 0-30
  delay(200);
  dfSend("AT+PAUSE");       // stop anything playing
  delay(200);
}



void setupProximity() {
  i2cSend(VCNL_ADDR,   0x00, 0x01);
  i2cSend16(VCNL_ADDR, 0x03, 0x04, 0x08);
  i2cSend16(VCNL_ADDR, 0x04, 0x00, 0x07);
}

bool magnetClose() {
  return i2cGet(VCNL_ADDR, 0x08) > PROX_THRESHOLD;
}



bool reedTriggered() {
  int r1 = analogRead(REED_PIN);
  delay(5);
  int r2 = analogRead(REED_PIN);
  delay(5);
  int r3 = analogRead(REED_PIN);
  return (r1 > 700 && r2 > 700 && r3 > 700);
}



void pollEncoder() {
  bool current = (analogRead(ENCODER_PIN) > 512);
  if (current && !lastEncoder) {
    if (!playing)
      gameStart = true;
    else
      dialCount++;
  }
  lastEncoder = current;
}

void resetJiggle() {
  jiggleCount  = 0;
  lastMagnet   = magnetClose();
  fireArmed    = false;
  jiggleArmed  = false;
  vcnlArmed    = false;
}

void pollJiggle() {
  bool current = magnetClose();
  if (!jiggleArmed) {
    if (!current) jiggleArmed = true;
    lastMagnet = current;
    return;
  }
  if (current && !lastMagnet)
    jiggleCount++;
  lastMagnet = current;
}

void pollFireArm() {
  if (!fireArmed && !reedTriggered()) {
    fireArmed = true;
  }
}

void pollVcnlArm() {
  if (!vcnlArmed && !magnetClose()) {
    vcnlArmed = true;
  }
}



void oledCmd(uint8_t cmd) {
  Wire.beginTransmission(OLED_ADDR);
  Wire.write(0x00);
  Wire.write(cmd);
  Wire.endTransmission();
}

void oledData(uint8_t data) {
  Wire.beginTransmission(OLED_ADDR);
  Wire.write(0x40);
  Wire.write(data);
  Wire.endTransmission();
}

void oledInit() {
  delay(100);
  oledCmd(0xAE);
  oledCmd(0xA8); oledCmd(0x3F);
  oledCmd(0xD3); oledCmd(0x00);
  oledCmd(0x40);
  oledCmd(0xA1);
  oledCmd(0xC8);
  oledCmd(0xDA); oledCmd(0x12);
  oledCmd(0x81); oledCmd(0xCF);
  oledCmd(0xA4);
  oledCmd(0xA6);
  oledCmd(0xD5); oledCmd(0x80);
  oledCmd(0xD9); oledCmd(0xF1);
  oledCmd(0xDB); oledCmd(0x40);
  oledCmd(0x20); oledCmd(0x00);
  oledCmd(0x8D); oledCmd(0x14);
  oledCmd(0xAF);
}

void oledClear() {
  for (uint8_t page = 0; page < 8; page++) {
    oledCmd(0xB0 + page);
    oledCmd(0x00);
    oledCmd(0x10);
    for (uint8_t col = 0; col < 128; col++)
      oledData(0x00);
  }
}

void oledSetCursor(uint8_t col, uint8_t page) {
  oledCmd(0xB0 + page);
  oledCmd(0x00 + (col & 0x0F));
  oledCmd(0x10 + (col >> 4));
}

